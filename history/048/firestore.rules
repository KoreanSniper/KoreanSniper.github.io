rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "seoul2linejh@gmail.com";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPostLikeToggle() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["likes", "dislikes"])
        && request.resource.data.uid == resource.data.uid;
    }

    function isCommentReactionToggle() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["likes", "dislikes"])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.postId == resource.data.postId
        && request.resource.data.content == resource.data.content;
    }

    function roomIsParticipant() {
      return signedIn()
        && (
          resource.data.hostId == request.auth.uid
          || resource.data.guestId == request.auth.uid
        );
    }

    function roomCommonFieldsValid() {
      return request.resource.data.keys().hasAll([
        "status",
        "hostId",
        "hostName",
        "createdAt",
        "updatedAt",
        "state"
      ])
      && request.resource.data.hostId == resource.data.hostId
      && request.resource.data.hostName == resource.data.hostName
      && request.resource.data.createdAt == resource.data.createdAt;
    }

    function roomIsStale() {
      return resource.data.updatedAt is timestamp
        && resource.data.updatedAt < request.time - duration.value(5, 'm');
    }

    function roomHostUpdateAllowed() {
      return signedIn()
        && request.auth.uid == resource.data.hostId
        && roomCommonFieldsValid()
        && request.resource.data.guestId == resource.data.guestId
        && request.resource.data.guestName == resource.data.guestName
        && request.resource.data.winner == resource.data.winner
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["status", "updatedAt"])
        && (
          (
            resource.data.status == "waiting"
            && request.resource.data.status in ["waiting", "cancelled"]
          )
        );
    }

    function roomGuestJoinAllowed() {
      return signedIn()
        && resource.data.status == "waiting"
        && resource.data.guestId == null
        && request.resource.data.status == "active"
        && request.resource.data.guestId == request.auth.uid
        && request.resource.data.guestName is string
        && request.resource.data.hostId == resource.data.hostId
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["status", "guestId", "guestName", "updatedAt"]);
    }

    function roomActiveParticipantUpdateAllowed() {
      return signedIn()
        && resource.data.status == "active"
        && roomCommonFieldsValid()
        && request.resource.data.guestId == resource.data.guestId
        && request.resource.data.guestName == resource.data.guestName
        && (
          (
            request.resource.data.status == "active"
            && request.resource.data.winner == resource.data.winner
          )
          ||
          request.resource.data.status == "ended"
        )
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["status", "state", "winner", "updatedAt"])
        && (
          request.auth.uid == resource.data.hostId
          || request.auth.uid == resource.data.guestId
        );
    }

    function roomDeleteAllowed() {
      return signedIn()
        && (
          request.auth.uid == resource.data.hostId
          || request.auth.uid == resource.data.guestId
          || roomIsStale()
          || isAdmin()
        );
    }

    function minigameRoomData(roomId) {
      return get(/databases/$(database)/documents/minigameRooms/$(roomId));
    }

    function minigameRoomParticipant(roomId) {
      return signedIn()
        && (
          minigameRoomData(roomId).data.hostId == request.auth.uid
          || minigameRoomData(roomId).data.guestId == request.auth.uid
        );
    }

    // =====================
    // PROFILES
    // =====================
    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwner(userId) || isAdmin();

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if isOwner(userId) || isAdmin();
    }

    // =====================
    // POSTS
    // =====================
    match /posts/{postId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(["title", "content", "uid", "email"]);

      allow update: if signedIn()
        && (
          isPostLikeToggle()
          || (
            (resource.data.uid == request.auth.uid || isAdmin())
            && request.resource.data.uid == resource.data.uid
          )
        );

      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // =====================
    // COMMENTS
    // =====================
    match /comments/{commentId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(["postId", "content", "uid"]);

      allow update: if isCommentReactionToggle();

      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // =====================
    // POST LIKES
    // =====================
    match /likes/{likeId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type in ["like", "dislike"];

      allow update: if false;

      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // =====================
    // COMMENT LIKES
    // =====================
    match /comment_likes/{likeId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type in ["like", "dislike"];

      allow update: if false;

      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // =====================
    // POST REPORTS
    // =====================
    match /reports/{reportId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.reason is string;

      allow update, delete: if false;
    }

    // =====================
    // COMMENT REPORTS
    // =====================
    match /comment_reports/{reportId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.commentId is string
        && request.resource.data.reason is string;

      allow update, delete: if false;
    }

    // =====================
    // MINIGAME ROOMS
    // =====================
    match /minigameRooms/{roomId} {
      allow read: if signedIn()
        && (
          resource.data.status == "waiting"
          || resource.data.hostId == request.auth.uid
          || resource.data.guestId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.status == "waiting"
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.hostName is string
        && request.resource.data.state is map;

      allow update: if signedIn()
        && roomCommonFieldsValid()
        && (
          roomHostUpdateAllowed()
          || roomGuestJoinAllowed()
          || roomActiveParticipantUpdateAllowed()
        );

      allow delete: if roomDeleteAllowed();
    }

    // =====================
    // MINIGAME CHAT
    // =====================
    match /minigameRooms/{roomId}/chat/{messageId} {
      allow read: if minigameRoomParticipant(roomId);

      allow create: if minigameRoomParticipant(roomId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 180
        && request.resource.data.keys().hasAll(["uid", "name", "text", "clientTs", "createdAt"]);

      allow update, delete: if false;
    }

    // =====================
    // GOMOKU ROOMS
    // =====================
    match /gomokuRooms/{roomId} {
      allow read: if signedIn()
        && (
          resource.data.status == "waiting"
          || resource.data.status == "active"
          || resource.data.status == "ended"
          || resource.data.hostId == request.auth.uid
          || resource.data.guestId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.status == "waiting"
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.hostName is string
        && request.resource.data.state is map;

      allow update: if signedIn()
        && roomCommonFieldsValid()
        && (
          roomHostUpdateAllowed()
          || roomGuestJoinAllowed()
          || roomActiveParticipantUpdateAllowed()
        );

      allow delete: if roomDeleteAllowed();
    }

    // =====================
    // GOMOKU MATCHMAKING
    // =====================
    match /gomokuMatchmaking/{docId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && request.auth.uid == request.resource.data.hostId
        && request.resource.data.keys().hasOnly(["roomId", "hostId", "updatedAt"])
        && request.resource.data.roomId is string;

      allow delete: if signedIn()
        && request.auth.uid == resource.data.hostId;
    }

    // =====================
    // GOMOKU CHAT
    // =====================
    match /gomokuRooms/{roomId}/chat/{messageId} {
      allow read: if signedIn()
        && (
          get(/databases/$(database)/documents/gomokuRooms/$(roomId)).data.status in ["waiting", "active", "ended"]
          || get(/databases/$(database)/documents/gomokuRooms/$(roomId)).data.hostId == request.auth.uid
          || get(/databases/$(database)/documents/gomokuRooms/$(roomId)).data.guestId == request.auth.uid
        );

      allow create: if signedIn()
        && (
          get(/databases/$(database)/documents/gomokuRooms/$(roomId)).data.status in ["waiting", "active", "ended"]
          || get(/databases/$(database)/documents/gomokuRooms/$(roomId)).data.hostId == request.auth.uid
          || get(/databases/$(database)/documents/gomokuRooms/$(roomId)).data.guestId == request.auth.uid
        )
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 180
        && request.resource.data.keys().hasAll(["uid", "name", "text", "clientTs", "createdAt"]);

      allow update, delete: if false;
    }

    // =====================
    // GOMOKU AI MEMORY
    // =====================
    match /gomokuAiMemory/{memoryId} {
      allow read, write: if signedIn();
    }
  }
}
